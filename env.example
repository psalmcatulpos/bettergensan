# =============================================================================
# BetterGensan environment template
# =============================================================================
# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored and MUST NEVER be committed.

# -----------------------------------------------------------------------------
# Government identity (used for SEO, branding, and contact links)
# -----------------------------------------------------------------------------
VITE_GOVERNMENT_NAME="General Santos City"
VITE_GOVERNMENT_TYPE="City"
VITE_REGION="Region XII"
VITE_PROVINCE="South Cotabato"

# -----------------------------------------------------------------------------
# Public website
# -----------------------------------------------------------------------------
VITE_WEBSITE_URL="https://your-domain.tld"
VITE_CONTACT_EMAIL="info@gensantos.gov.ph"
VITE_CONTACT_PHONE="(083) 552-2986"

# -----------------------------------------------------------------------------
# Social media
# -----------------------------------------------------------------------------
VITE_FACEBOOK_URL="https://www.facebook.com/bettergovph"
VITE_TWITTER_URL=""
VITE_INSTAGRAM_URL=""
VITE_YOUTUBE_URL=""

# -----------------------------------------------------------------------------
# SEO
# -----------------------------------------------------------------------------
VITE_SITE_DESCRIPTION="Community-run civic portal for General Santos City"
VITE_SITE_KEYWORDS="General Santos City, GenSan, government services, local government, South Cotabato, Region XII"
VITE_OG_IMAGE_URL=""
VITE_TWITTER_HANDLE=""

# -----------------------------------------------------------------------------
# Optional analytics
# -----------------------------------------------------------------------------
VITE_GOOGLE_ANALYTICS_ID=""
VITE_FACEBOOK_PIXEL_ID=""

# -----------------------------------------------------------------------------
# Supabase
#   - VITE_SUPABASE_URL    : your project URL (e.g. https://xxx.supabase.co)
#   - VITE_SUPABASE_ANON_KEY: PUBLISHABLE / anon key (safe for the browser)
#
# NEVER put the SERVICE ROLE key here. Service role belongs in Supabase edge
# function env or the Vault — never in any VITE_* variable, never in any
# frontend file.
# -----------------------------------------------------------------------------
VITE_SUPABASE_URL=""
VITE_SUPABASE_ANON_KEY=""

# -----------------------------------------------------------------------------
# Regiment API key (server-side only — NO VITE_ prefix on purpose)
# -----------------------------------------------------------------------------
# Used by the Vite dev proxy in vite.config.ts to call regiment.me from the
# dev server without exposing the key to the browser. In production this key
# lives in Supabase edge function env / Vault, NOT in the deployed bundle.
REGIMENT_API_KEY=""
