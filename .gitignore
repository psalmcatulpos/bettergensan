scripts/.backfill/
scripts/.gensan-*-backfill.sql
scripts/.*.sql
# One-shot Phase-1 backfill helpers — target a now-deleted edge function
# and hardcode the Supabase URL + anon key. Operator-only, do not publish.
scripts/gensan-backfill-helper.cjs
scripts/gensan-bulk-post.cjs

# Raw data downloads / working exports (processed data lives in src/data/)
HDX Pop Density/
command-center-export/

